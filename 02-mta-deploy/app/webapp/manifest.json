{
  "sap.app": {
    "id": "appfront.mta.demo",
    "type": "application",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}"
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "appfront.mta.demo.view.App",
      "type": "XML",
      "id": "appView"
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "appfront.mta.demo.i18n.i18n"
        }
      }
    }
  }
}
