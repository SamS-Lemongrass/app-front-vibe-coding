<mvc:View
    controllerName="appfront.mta.demo.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="Task Board" showFooter="true">
        <subHeader>
            <Toolbar>
                <Input id="newTaskInput" placeholder="Add a new task..." width="100%" submit=".onAddTask" />
                <Button icon="sap-icon://add" type="Emphasized" press=".onAddTask" tooltip="Add Task" />
            </Toolbar>
        </subHeader>
        <content>
            <List id="taskList" items="{/tasks}" noDataText="No tasks yet">
                <StandardListItem
                    title="{title}"
                    description="{category}"
                    info="{priority}"
                    infoState="{priorityState}"
                    icon="{statusIcon}"
                    highlight="{priorityState}"
                    type="Active"
                    press=".onToggleTask" />
            </List>
        </content>
        <footer>
            <Toolbar>
                <Button text="All" press=".onFilterAll" />
                <Button text="Open" press=".onFilterOpen" />
                <Button text="Done" press=".onFilterDone" />
                <ToolbarSpacer />
                <Button text="Clear Completed" type="Reject" press=".onClearCompleted" />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
