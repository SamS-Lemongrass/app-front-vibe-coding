<mvc:View
    controllerName="appfront.mta.demo.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="Task Board" showFooter="true">
        <headerContent>
            <Title text="{= ${/tasks}.length + ' tasks'}" />
        </headerContent>
        <subHeader>
            <Toolbar>
                <Input id="newTaskInput" placeholder="Add a new task..." width="100%" submit=".onAddTask" />
                <Button icon="sap-icon://add" type="Emphasized" press=".onAddTask" tooltip="Add Task" />
            </Toolbar>
        </subHeader>
        <content>
            <IconTabBar id="iconTabBar" select=".onFilterSelect" selectedKey="all" class="sapUiNoContentPadding">
                <items>
                    <IconTabFilter key="all" text="All" count="{= ${/tasks}.length}" icon="sap-icon://list" />
                    <IconTabFilter key="open" text="Open" count="{/openCount}" icon="sap-icon://pending" iconColor="Critical" />
                    <IconTabFilter key="done" text="Done" count="{/doneCount}" icon="sap-icon://accept" iconColor="Positive" />
                </items>
                <content>
                    <List id="taskList" items="{/tasks}" noDataText="No tasks yet — add one above!">
                        <ObjectListItem
                            title="{title}"
                            number="{priority}"
                            numberState="{= ${priority} === 'High' ? 'Error' : (${priority} === 'Medium' ? 'Warning' : 'Success')}"
                            type="Active"
                            icon="{= ${done} ? 'sap-icon://accept' : 'sap-icon://circle-task-2'}"
                            press=".onToggleTask">
                            <attributes>
                                <ObjectAttribute text="{category}" />
                                <ObjectAttribute text="{= ${done} ? 'Completed' : 'Open'}" />
                            </attributes>
                        </ObjectListItem>
                    </List>
                </content>
            </IconTabBar>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button text="Clear Completed" type="Reject" press=".onClearCompleted" />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
